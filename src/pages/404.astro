---
import MainLayout from "../layouts/Layout.astro";
---

<MainLayout title="404 - Page Not Found" description="The page you're looking for doesn't exist.">
  <div class="min-h-screen flex items-center justify-center bg-gradient-to-br from-gray-950 via-gray-900 to-gray-950">
    <div class="max-w-2xl mx-auto px-6 py-20 text-center">
      <h1 class="text-9xl font-bold text-violet-500 mb-6">404</h1>
      <h2 class="text-4xl font-bold text-white mb-4">Page Not Found</h2>
      <p class="text-xl text-gray-400 mb-8">
        The page you're looking for doesn't exist or has been moved.
      </p>
      <a
        href="/"
        class="inline-flex items-center gap-2 px-8 py-3 bg-violet-600 text-white rounded-lg font-semibold hover:bg-violet-500 transition-colors shadow-lg shadow-violet-500/20"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
        </svg>
        Go Back Home
      </a>
    </div>
  </div>
</MainLayout>
