      <div style="color:#d1d5db;">10 checks per session, then Chrome is recycled and the cycle repeats. The whole session is wrapped in <span style="color:#a78bfa;font-family:monospace">retry_on_failure</span> — if it crashes, it retries up to 2× before alerting me. Outer loop runs forever.</div>
    `,
    driver: `
      <div style="font-weight:600;margin-bottom:8px;">driver_manager</div>
      <div style="color:#d1d5db;">Creates and destroys Chrome. Checks if alive via <span style="color:#6ee7b7;font-family:monospace">driver.current_url</span>. Cleans up <span style="color:#6ee7b7;font-family:monospace">/tmp/chrome_jobbot</span> even if <span style="color:#6ee7b7;font-family:monospace">quit()</span> fails. Runs headless with 3 anti-detection flags + JS webdriver property override.</div>
    `,
    errors: `
      <div style="font-weight:600;margin-bottom:8px;">error_handling</div>
      <div style="display:flex;flex-direction:column;gap:5px;color:#d1d5db;">
        <div><span style="color:#fcd34d;">TemporaryError</span> — retry silently up to 2×</div>
        <div><span style="color:#f87171;">PermanentError</span> — stop immediately, alert us both</div>
        <div><span style="color:#fb923c;">TooManyFailuresError</span> — max retries hit, escalates to permanent</div>
      </div>
    `,
    timing: `
      <div style="font-weight:600;margin-bottom:8px;">timing</div>
      <div style="color:#d1d5db;display:flex;flex-direction:column;gap:3px;">
        <div>· 5–25 min &nbsp;·&nbsp; mornings</div>
        <div>· 2–8 min &nbsp;·&nbsp; evenings</div>
        <div>· Up to 4.5 hrs &nbsp;·&nbsp; overnight</div>
        <div style="margin-top:8px;">Randomized within each range — prevents predictable bot patterns.</div>
      </div>
    `,
    notifications: `
      <div style="font-weight:600;margin-bottom:8px;">notifications</div>
      <div style="color:#d1d5db;display:flex;flex-direction:column;gap:7px;">
        <div>Two recipient tiers via Pushover API:</div>
        <div style="border-left:2px solid #7c3aed;padding-left:8px;">
          <div style="color:#c4b5fd;font-family:monospace;margin-bottom:2px;">notify_users()</div>
          <div>Sister + me · job alerts + screenshots</div>
        </div>
        <div style="border-left:2px solid #4b5563;padding-left:8px;">
          <div style="color:#9ca3af;font-family:monospace;margin-bottom:2px;">notify_admin()</div>
          <div>Me only · errors + debug info</div>
        </div>
        <div>Screenshots are attached then deleted from disk.</div>
      </div>
    `,
  };

  const tooltip = document.getElementById("arch-tooltip") as HTMLElement | null;
  const modules = document.querySelectorAll<SVGGElement>(".arch-module");

  if (tooltip) {
    modules.forEach((module) => {
      const key = module.dataset.module ?? "";

      module.addEventListener("mouseenter", () => {
        tooltip.innerHTML = tooltipContent[key] ?? "";
        tooltip.style.display = "block";
      });

      module.addEventListener("mouseleave", () => {
        tooltip.style.display = "none";
      });
    });

    document.addEventListener("mousemove", (e) => {
      if (tooltip.style.display === "none") return;
      let x = e.clientX + 14;
      let y = e.clientY + 14;
      if (x + 240 > window.innerWidth - 8) x = e.clientX - 254;
      if (y + tooltip.offsetHeight > window.innerHeight - 8) {
        y = e.clientY - tooltip.offsetHeight - 14;
      }
      tooltip.style.left = x + "px";
      tooltip.style.top = y + "px";
    });
  }
</script>
