---
import MainLayout from "../../layouts/Layout.astro";
import Nav from "../../components/Nav.astro";
import Footer from "../../components/Footer.astro";

const tags = ["Python", "Selenium", "BeautifulSoup", "Pushover API"];
---

<MainLayout
  title="Jobbot"
  description="A real-time job monitoring and auto-accept system built for substitute teachers"
>
  <Nav />

  <main class="bg-gray-50 min-h-screen">
    <!-- Hero with gradient -->
    <div class="relative overflow-hidden">
      <div
        class="absolute inset-0 bg-gradient-to-br from-violet-100 via-gray-50 to-gray-50"
      >
      </div>
      <div
        class="absolute top-20 left-1/4 w-96 h-96 bg-violet-200/50 rounded-full blur-3xl"
      >
      </div>
      <div
        class="absolute top-40 right-1/4 w-64 h-64 bg-violet-300/40 rounded-full blur-3xl"
      >
      </div>

      <div class="relative pt-32 pb-20 px-6">
        <!-- Back link -->
        <div class="max-w-4xl mx-auto mb-8">
          <a
            href="/#projects"
            class="text-violet-600 hover:text-violet-700 transition-colors inline-flex items-center gap-2 text-sm"
          >
            <svg
              class="w-4 h-4"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M15 19l-7-7 7-7"></path>
            </svg>
            Back to projects
          </a>
        </div>

        <!-- Hero content -->
        <header class="max-w-4xl mx-auto">
          <h1
            class="text-5xl md:text-6xl font-bold text-gray-900 mb-6 tracking-tight"
          >
            Jobbot
          </h1>

          <p
            class="text-xl md:text-xl text-gray-600 mb-8 leading-relaxed max-w-2xl"
          >
            A real-time job monitoring system that scrapes postings and
            auto-accepts opportunities before they're gone.
          </p>

          <div class="flex flex-wrap gap-3 mb-8">
            {
              tags.map((tag) => (
                <span class="px-4 py-2 bg-violet-100 text-violet-700 rounded-lg text-sm font-medium border border-violet-200 backdrop-blur-sm">
                  {tag}
                </span>
              ))
            }
          </div>

          <a
            href="https://github.com/jen444x/job-alert-automation"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-5 py-3 bg-gray-900 text-white font-semibold rounded-xl hover:bg-gray-800 transition-colors"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path
                d="M12 .3a12 12 0 0 0-3.8 23.4c.6.1.8-.3.8-.6v-2c-3.3.7-4-1.6-4-1.6-.6-1.4-1.4-1.8-1.4-1.8-1-.7.1-.7.1-.7 1.2 0 1.9 1.2 1.9 1.2 1 1.8 2.8 1.3 3.5 1 0-.8.4-1.3.7-1.6-2.7-.3-5.5-1.3-5.5-6 0-1.2.5-2.3 1.3-3.1-.2-.4-.6-1.6 0-3.2 0 0 1-.3 3.4 1.2a11.5 11.5 0 0 1 6 0c2.3-1.5 3.3-1.2 3.3-1.2.6 1.6.2 2.8 0 3.2.9.8 1.3 1.9 1.3 3.2 0 4.6-2.8 5.6-5.5 5.9.5.4.9 1 .9 2.2v3.3c0 .3.1.7.8.6A12 12 0 0 0 12 .3"
              ></path>
            </svg>
            View on GitHub
          </a>
        </header>
      </div>
    </div>

    <!-- Content -->
    <article class="max-w-4xl mx-auto px-6 pb-20">
      <!-- Motivation -->
      <section class="mb-20">
        <div class="flex items-center gap-3 mb-6">
          <div
            class="w-10 h-10 bg-violet-100 rounded-xl flex items-center justify-center"
          >
            <svg
              class="w-5 h-5 text-violet-600"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"
              ></path>
            </svg>
          </div>
          <h2 class="text-2xl font-bold text-gray-900">The Story</h2>
        </div>

        <p class="text-gray-600 leading-relaxed mb-8 text-lg">
          My sister worked as a substitute teacher. Job postings go up at random
          times, and if you don't claim them fast, someone else will. So I built
          a bot that runs 24/7, checks the portal every few minutes, and accepts
          jobs automatically.
        </p>

        <!-- Problem / Solution cards -->
        <div class="grid md:grid-cols-2 gap-4 relative">
          <!-- Problem -->
          <div class="relative">
            <div
              class="absolute -top-3 left-4 px-3 py-1 bg-gray-100 text-gray-600 text-xs font-semibold rounded-full border border-gray-200"
            >
              BEFORE
            </div>
            <div
              class="bg-white rounded-2xl p-6 pt-8 border border-gray-200 h-full shadow-sm hover:shadow-md transition-shadow"
            >
              <ul class="space-y-2">
                <li class="flex items-center gap-3 text-gray-600 text-sm">
                  <span class="w-1.5 h-1.5 bg-gray-400 rounded-full shrink-0"
                  ></span>
                  Constantly checking her phone
                </li>
                <li class="flex items-center gap-3 text-gray-600 text-sm">
                  <span class="w-1.5 h-1.5 bg-gray-400 rounded-full shrink-0"
                  ></span>
                  Missing jobs when not checking
                </li>
                <li class="flex items-center gap-3 text-gray-600 text-sm">
                  <span class="w-1.5 h-1.5 bg-gray-400 rounded-full shrink-0"
                  ></span>
                  Waking up extra early
                </li>
                <li class="flex items-center gap-3 text-gray-600 text-sm">
                  <span class="w-1.5 h-1.5 bg-gray-400 rounded-full shrink-0"
                  ></span>
                  Staying up late checking
                </li>
              </ul>
            </div>
          </div>

          <!-- Arrow connector -->
          <div
            class="hidden md:flex absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 z-10"
          >
            <div
              class="w-10 h-10 bg-white rounded-full flex items-center justify-center border border-gray-200 shadow-sm"
            >
              <svg
                class="w-5 h-5 text-violet-600"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
              </svg>
            </div>
          </div>

          <!-- Solution -->
          <div class="relative">
            <div
              class="absolute -top-3 left-4 px-3 py-1 bg-violet-100 text-violet-600 text-xs font-semibold rounded-full border border-violet-200"
            >
              AFTER
            </div>
            <div
              class="bg-white rounded-2xl p-6 pt-8 border border-gray-200 h-full shadow-sm hover:shadow-md transition-shadow"
            >
              <ul class="space-y-2">
                <li class="flex items-center gap-3 text-gray-600 text-sm">
                  <span class="w-1.5 h-1.5 bg-violet-500 rounded-full shrink-0"
                  ></span>
                  Auto-accept or notify only mode
                </li>
                <li class="flex items-center gap-3 text-gray-600 text-sm">
                  <span class="w-1.5 h-1.5 bg-violet-500 rounded-full shrink-0"
                  ></span>
                  Configurable job preferences
                </li>
                <li class="flex items-center gap-3 text-gray-600 text-sm">
                  <span class="w-1.5 h-1.5 bg-violet-500 rounded-full shrink-0"
                  ></span>
                  Blackout dates
                </li>
                <li class="flex items-center gap-3 text-gray-600 text-sm">
                  <span class="w-1.5 h-1.5 bg-violet-500 rounded-full shrink-0"
                  ></span>
                  Optimized check frequency
                </li>
              </ul>
            </div>
          </div>
        </div>
      </section>

      <!-- How It Works -->
      <section class="mb-20">
        <div class="flex items-center gap-3 mb-6">
          <div
            class="w-10 h-10 bg-violet-100 rounded-xl flex items-center justify-center"
          >
            <svg
              class="w-5 h-5 text-violet-600"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M13 5l7 7-7 7M5 5l7 7-7 7"
              ></path>
            </svg>
          </div>
          <h2 class="text-2xl font-bold text-gray-900">How It Works</h2>
        </div>

        <!-- Desktop: horizontal row -->
        <div class="hidden md:grid md:grid-cols-4 gap-4 relative">
          <!-- Connecting line behind cards -->
          <div class="absolute top-10 left-[12.5%] right-[12.5%] h-px bg-gradient-to-r from-violet-300 via-violet-400 to-violet-300 z-0"></div>

          <!-- Step 1 -->
          <div class="relative z-10 bg-white rounded-xl p-5 border border-gray-200 shadow-sm">
            <span class="text-violet-500 text-xs font-semibold tracking-wide">01</span>
            <h3 class="text-gray-900 font-semibold mt-1 mb-2">Login</h3>
            <p class="text-gray-500 text-sm leading-relaxed">Selenium handles browser automation, logging into the portal and navigating to postings.</p>
          </div>

          <!-- Step 2 -->
          <div class="relative z-10 bg-white rounded-xl p-5 border border-gray-200 shadow-sm">
            <span class="text-violet-500 text-xs font-semibold tracking-wide">02</span>
            <h3 class="text-gray-900 font-semibold mt-1 mb-2">Scrape</h3>
            <p class="text-gray-500 text-sm leading-relaxed">BeautifulSoup extracts job details. Duplicate detection ensures we only process new postings.</p>
          </div>

          <!-- Step 3 -->
          <div class="relative z-10 bg-white rounded-xl p-5 border border-gray-200 shadow-sm">
            <span class="text-violet-500 text-xs font-semibold tracking-wide">03</span>
            <h3 class="text-gray-900 font-semibold mt-1 mb-2">Accept</h3>
            <p class="text-gray-500 text-sm leading-relaxed">When a matching job appears, the bot clicks through and accepts it automatically.</p>
          </div>

          <!-- Step 4 -->
          <div class="relative z-10 bg-white rounded-xl p-5 border border-gray-200 shadow-sm">
            <span class="text-violet-500 text-xs font-semibold tracking-wide">04</span>
            <h3 class="text-gray-900 font-semibold mt-1 mb-2">Notify</h3>
            <p class="text-gray-500 text-sm leading-relaxed">Pushover sends an instant alert to her phone with job details. She knows she's booked.</p>
          </div>
        </div>

        <!-- Mobile: stacked -->
        <div class="md:hidden space-y-3">
          <div class="bg-white rounded-xl p-4 border border-gray-200 shadow-sm flex gap-4">
            <span class="text-violet-500 text-xs font-semibold">01</span>
            <div>
              <h3 class="text-gray-900 font-semibold text-sm mb-1">Login</h3>
              <p class="text-gray-500 text-sm">Selenium automates browser login and navigation.</p>
            </div>
          </div>
          <div class="bg-white rounded-xl p-4 border border-gray-200 shadow-sm flex gap-4">
            <span class="text-violet-500 text-xs font-semibold">02</span>
            <div>
              <h3 class="text-gray-900 font-semibold text-sm mb-1">Scrape</h3>
              <p class="text-gray-500 text-sm">BeautifulSoup extracts and deduplicates job data.</p>
            </div>
          </div>
          <div class="bg-white rounded-xl p-4 border border-gray-200 shadow-sm flex gap-4">
            <span class="text-violet-500 text-xs font-semibold">03</span>
            <div>
              <h3 class="text-gray-900 font-semibold text-sm mb-1">Accept</h3>
              <p class="text-gray-500 text-sm">Auto-clicks to claim matching jobs instantly.</p>
            </div>
          </div>
          <div class="bg-white rounded-xl p-4 border border-gray-200 shadow-sm flex gap-4">
            <span class="text-violet-500 text-xs font-semibold">04</span>
            <div>
              <h3 class="text-gray-900 font-semibold text-sm mb-1">Notify</h3>
              <p class="text-gray-500 text-sm">Pushover sends instant phone alerts with details.</p>
            </div>
          </div>
        </div>
      </section>

      <!-- How It Stays Running -->
      <section class="mb-20">
        <div class="flex items-center gap-3 mb-6">
          <div
            class="w-10 h-10 bg-violet-100 rounded-xl flex items-center justify-center"
          >
            <svg
              class="w-5 h-5 text-violet-600"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"
              ></path>
            </svg>
          </div>
          <h2 class="text-2xl font-bold text-gray-900">How It Stays Running</h2>
        </div>

        <p class="text-gray-600 mb-8">
          She trusted this bot enough to stop manually checking for jobs. If it failed, she'd miss a job—and that would be on me. I was funding this myself on a small DigitalOcean droplet, so I had to be smart about memory while making it reliable enough that she never had to worry.
        </p>

        <div class="grid md:grid-cols-3 gap-4">
          <div
            class="bg-white rounded-xl p-5 border border-gray-200 hover:border-violet-300 transition-colors shadow-sm"
          >
            <div class="text-violet-600 font-mono text-sm mb-2">TemporaryError vs PermanentError</div>
            <h3 class="text-gray-900 font-semibold mb-2">Not All Errors Are Equal</h3>
            <p class="text-gray-500 text-sm">
              Network hiccup? Retry silently. Credentials invalid? Stop and alert. She only hears about real problems. When something breaks, dump_debug() captures HTML and a screenshot so I can fix it without asking her what happened.
            </p>
          </div>

          <div
            class="bg-white rounded-xl p-5 border border-gray-200 hover:border-violet-300 transition-colors shadow-sm"
          >
            <div class="text-violet-600 font-mono text-sm mb-2">memory management</div>
            <h3 class="text-gray-900 font-semibold mb-2">Protecting the Droplet</h3>
            <p class="text-gray-500 text-sm">
              Small droplet meant being careful. Driver recreated every 10 cycles before memory bloats. Screenshots deleted after sending. Retries instead of recreations—cheaper on resources. Cleanup runs even if close() fails. No zombie processes eating RAM.
            </p>
          </div>

          <div
            class="bg-white rounded-xl p-5 border border-gray-200 hover:border-violet-300 transition-colors shadow-sm"
          >
            <div class="text-violet-600 font-mono text-sm mb-2">defensive checks</div>
            <h3 class="text-gray-900 font-semibold mb-2">Never Assume State</h3>
            <p class="text-gray-500 text-sm">
              Check driver is alive. Check logged in. Wait for elements to actually load. Verify before every action. Redundant? Yes. But she was trusting this completely—I couldn't afford to be wrong.
            </p>
          </div>
        </div>
      </section>

      <!-- How It Works For Her -->
      <section class="mb-20">
        <div class="flex items-center gap-3 mb-8">
          <div
            class="w-10 h-10 bg-violet-100 rounded-xl flex items-center justify-center"
          >
            <svg
              class="w-5 h-5 text-violet-600"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"
              ></path>
            </svg>
          </div>
          <h2 class="text-2xl font-bold text-gray-900">How It Works For Her</h2>
        </div>

        <div class="grid md:grid-cols-2 gap-4">
          <div
            class="bg-white rounded-xl p-5 border-l-4 border-l-violet-400 border-y border-r border-gray-200 shadow-sm hover:shadow-md transition-shadow"
          >
            <p class="text-violet-600 text-sm font-medium mb-2">
              What if she's sleeping and a job gets auto-accepted she doesn't
              want?
            </p>
            <div class="flex items-start gap-2">
              <svg
                class="w-4 h-4 text-gray-400 mt-0.5 shrink-0"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
              </svg>
              <p class="text-gray-600 text-sm">
                Added a same-day toggle. Off by default. If she wants a job
                today, she turns it on. If it's night and she hasn't gotten one
                and wants to try early tomorrow, she keeps it off.
              </p>
            </div>
          </div>

          <div
            class="bg-white rounded-xl p-5 border-l-4 border-l-violet-400 border-y border-r border-gray-200 shadow-sm hover:shadow-md transition-shadow"
          >
            <p class="text-violet-600 text-sm font-medium mb-2">
              What if auto-accept fails but the job is still there?
            </p>
            <div class="flex items-start gap-2">
              <svg
                class="w-4 h-4 text-gray-400 mt-0.5 shrink-0"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
              </svg>
              <p class="text-gray-600 text-sm">
                Notify her first when the job appears, then try to accept. If it
                fails, she still knows the job exists and can grab it herself.
              </p>
            </div>
          </div>

          <div
            class="bg-white rounded-xl p-5 border-l-4 border-l-violet-400 border-y border-r border-gray-200 shadow-sm hover:shadow-md transition-shadow"
          >
            <p class="text-violet-600 text-sm font-medium mb-2">
              What if it's a job she doesn't want, but she'd take it today?
            </p>
            <div class="flex items-start gap-2">
              <svg
                class="w-4 h-4 text-gray-400 mt-0.5 shrink-0"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
              </svg>
              <p class="text-gray-600 text-sm">
                Still notify her about all jobs, even ones outside her
                preferences. Maybe she doesn't have anything else lined up.
              </p>
            </div>
          </div>

          <div
            class="bg-white rounded-xl p-5 border-l-4 border-l-violet-400 border-y border-r border-gray-200 shadow-sm hover:shadow-md transition-shadow"
          >
            <p class="text-violet-600 text-sm font-medium mb-2">
              What if the accept fails and she doesn't know why?
            </p>
            <div class="flex items-start gap-2">
              <svg
                class="w-4 h-4 text-gray-400 mt-0.5 shrink-0"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
              </svg>
              <p class="text-gray-600 text-sm">
                Check for specific error messages like "job no longer available"
                and tell her the actual reason, not just "it failed."
              </p>
            </div>
          </div>

          <div
            class="bg-white rounded-xl p-5 border-l-4 border-l-violet-400 border-y border-r border-gray-200 shadow-sm hover:shadow-md transition-shadow"
          >
            <p class="text-violet-600 text-sm font-medium mb-2">
              What if the site changes and breaks the bot?
            </p>
            <div class="flex items-start gap-2">
              <svg
                class="w-4 h-4 text-gray-400 mt-0.5 shrink-0"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
              </svg>
              <p class="text-gray-600 text-sm">
                Save the page HTML and a screenshot when things fail so I can
                see exactly what happened and fix it without bothering her.
              </p>
            </div>
          </div>

          <div
            class="bg-white rounded-xl p-5 border-l-4 border-l-violet-400 border-y border-r border-gray-200 shadow-sm hover:shadow-md transition-shadow"
          >
            <p class="text-violet-600 text-sm font-medium mb-2">
              What if something fails but might work if we try again?
            </p>
            <div class="flex items-start gap-2">
              <svg
                class="w-4 h-4 text-gray-400 mt-0.5 shrink-0"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
              </svg>
              <p class="text-gray-600 text-sm">
                Retry silently on temporary errors. Only notify her when it's
                actually broken and needs attention.
              </p>
            </div>
          </div>
        </div>
      </section>

      <!-- Challenges -->
      <section class="mb-20">
        <div class="flex items-center gap-3 mb-8">
          <div
            class="w-10 h-10 bg-violet-100 rounded-xl flex items-center justify-center"
          >
            <svg
              class="w-5 h-5 text-violet-600"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"
              ></path>
            </svg>
          </div>
          <h2 class="text-2xl font-bold text-gray-900">Challenges</h2>
        </div>

        <div
          class="bg-white rounded-xl border border-gray-200 divide-y divide-gray-100 shadow-sm hover:shadow-md transition-shadow"
        >
          <div class="p-5 flex items-start gap-4">
            <div class="w-2 h-2 bg-violet-500 rounded-full mt-2 shrink-0"></div>
            <div>
              <h3 class="text-gray-900 font-medium mb-1">Session Management</h3>
              <p class="text-gray-500 text-sm">
                Handling timeouts and re-authentication when sessions expire
                mid-run.
              </p>
            </div>
          </div>
          <div class="p-5 flex items-start gap-4">
            <div class="w-2 h-2 bg-violet-500 rounded-full mt-2 shrink-0"></div>
            <div>
              <h3 class="text-gray-900 font-medium mb-1">
                Timing is Everything
              </h3>
              <p class="text-gray-500 text-sm">
                Too fast and elements aren't ready. Too slow and you miss jobs.
                Finding the balance took iteration.
              </p>
            </div>
          </div>
