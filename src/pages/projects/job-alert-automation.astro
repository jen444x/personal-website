---
import MainLayout from "../../layouts/Layout.astro";
import Nav from "../../components/Nav.astro";
import Footer from "../../components/Footer.astro";

const tags = ["Python", "Selenium", "BeautifulSoup", "Pushover API"];
---

<MainLayout
  title="Jobbot"
  description="A real-time job monitoring and auto-accept system built for substitute teachers"
>
  <Nav />

  <main class="bg-gray-50 min-h-screen">
    <!-- Hero with gradient -->
    <div class="relative overflow-hidden">
      <div
        class="absolute inset-0 bg-gradient-to-br from-violet-100 via-gray-50 to-gray-50"
      >
      </div>
      <div
        class="absolute top-20 left-1/4 w-96 h-96 bg-violet-200/50 rounded-full blur-3xl"
      >
      </div>
      <div
        class="absolute top-40 right-1/4 w-64 h-64 bg-violet-300/40 rounded-full blur-3xl"
      >
      </div>

      <div class="relative pt-32 pb-20 px-6">
        <!-- Back link -->
        <div class="max-w-4xl mx-auto mb-8">
          <a
            href="/#projects"
            class="text-violet-600 hover:text-violet-700 transition-colors inline-flex items-center gap-2 text-sm"
          >
            <svg
              class="w-4 h-4"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M15 19l-7-7 7-7"></path>
            </svg>
            Back to projects
          </a>
        </div>

        <!-- Hero content -->
        <header class="max-w-4xl mx-auto">
          <h1
            class="text-5xl md:text-6xl font-bold text-gray-900 mb-6 tracking-tight"
          >
            Jobbot
          </h1>

          <p
            class="text-xl md:text-xl text-gray-600 mb-8 leading-relaxed max-w-2xl"
          >
            A real-time job monitoring system that scrapes postings and
            auto-accepts opportunities before they're gone.
          </p>

          <div class="flex flex-wrap gap-3 mb-8">
            {
              tags.map((tag) => (
                <span class="px-4 py-2 bg-violet-100 text-violet-700 rounded-lg text-sm font-medium border border-violet-200 backdrop-blur-sm">
                  {tag}
                </span>
              ))
            }
          </div>

          <a
            href="https://github.com/jen444x/job-alert-automation"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-5 py-3 bg-gray-900 text-white font-semibold rounded-xl hover:bg-gray-800 transition-colors"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path
                d="M12 .3a12 12 0 0 0-3.8 23.4c.6.1.8-.3.8-.6v-2c-3.3.7-4-1.6-4-1.6-.6-1.4-1.4-1.8-1.4-1.8-1-.7.1-.7.1-.7 1.2 0 1.9 1.2 1.9 1.2 1 1.8 2.8 1.3 3.5 1 0-.8.4-1.3.7-1.6-2.7-.3-5.5-1.3-5.5-6 0-1.2.5-2.3 1.3-3.1-.2-.4-.6-1.6 0-3.2 0 0 1-.3 3.4 1.2a11.5 11.5 0 0 1 6 0c2.3-1.5 3.3-1.2 3.3-1.2.6 1.6.2 2.8 0 3.2.9.8 1.3 1.9 1.3 3.2 0 4.6-2.8 5.6-5.5 5.9.5.4.9 1 .9 2.2v3.3c0 .3.1.7.8.6A12 12 0 0 0 12 .3"
              ></path>
            </svg>
            View on GitHub
          </a>
        </header>
      </div>
    </div>

    <!-- Content -->
    <article class="max-w-4xl mx-auto px-6 pb-20">
      <!-- Motivation -->
      <section class="mb-20">
        <div class="flex items-center gap-3 mb-6">
          <div
            class="w-10 h-10 bg-violet-100 rounded-xl flex items-center justify-center"
          >
            <svg
              class="w-5 h-5 text-violet-600"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"
              ></path>
            </svg>
          </div>
          <h2 class="text-2xl font-bold text-gray-900">The Story</h2>
        </div>

        <p class="text-gray-600 leading-relaxed mb-8 text-lg">
          My sister worked as a substitute teacher. Job postings go up at random
          times, and if you don't claim them fast, someone else will. So I built
          a bot that runs 24/7, checks the portal every few minutes, and accepts
          jobs automatically.
        </p>

        <!-- Problem / Solution cards -->
        <div class="grid md:grid-cols-2 gap-4 relative">
          <!-- Problem -->
          <div class="relative">
            <div
              class="absolute -top-3 left-4 px-3 py-1 bg-gray-100 text-gray-600 text-xs font-semibold rounded-full border border-gray-200"
            >
              BEFORE
            </div>
            <div
              class="bg-white rounded-2xl p-6 pt-8 border border-gray-200 h-full shadow-sm hover:shadow-md transition-shadow"
            >
              <ul class="space-y-2">
                <li class="flex items-center gap-3 text-gray-600 text-sm">
                  <span class="w-1.5 h-1.5 bg-gray-400 rounded-full shrink-0"
                  ></span>
                  Constantly checking her phone
                </li>
                <li class="flex items-center gap-3 text-gray-600 text-sm">
                  <span class="w-1.5 h-1.5 bg-gray-400 rounded-full shrink-0"
                  ></span>
                  Missing jobs when not checking
                </li>
                <li class="flex items-center gap-3 text-gray-600 text-sm">
                  <span class="w-1.5 h-1.5 bg-gray-400 rounded-full shrink-0"
                  ></span>
                  Waking up extra early
                </li>
                <li class="flex items-center gap-3 text-gray-600 text-sm">
                  <span class="w-1.5 h-1.5 bg-gray-400 rounded-full shrink-0"
                  ></span>
                  Staying up late checking
                </li>
              </ul>
            </div>
          </div>

          <!-- Arrow connector -->
          <div
            class="hidden md:flex absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 z-10"
          >
            <div
              class="w-10 h-10 bg-white rounded-full flex items-center justify-center border border-gray-200 shadow-sm"
            >
              <svg
                class="w-5 h-5 text-violet-600"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
              </svg>
            </div>
          </div>

          <!-- Solution -->
          <div class="relative">
            <div
              class="absolute -top-3 left-4 px-3 py-1 bg-violet-100 text-violet-600 text-xs font-semibold rounded-full border border-violet-200"
            >
              AFTER
            </div>
            <div
              class="bg-white rounded-2xl p-6 pt-8 border border-gray-200 h-full shadow-sm hover:shadow-md transition-shadow"
            >
              <ul class="space-y-2">
                <li class="flex items-center gap-3 text-gray-600 text-sm">
                  <span class="w-1.5 h-1.5 bg-violet-500 rounded-full shrink-0"
                  ></span>
                  Auto-accept or notify only mode
                </li>
                <li class="flex items-center gap-3 text-gray-600 text-sm">
                  <span class="w-1.5 h-1.5 bg-violet-500 rounded-full shrink-0"
                  ></span>
                  Configurable job preferences
                </li>
                <li class="flex items-center gap-3 text-gray-600 text-sm">
                  <span class="w-1.5 h-1.5 bg-violet-500 rounded-full shrink-0"
                  ></span>
                  Blackout dates
                </li>
                <li class="flex items-center gap-3 text-gray-600 text-sm">
                  <span class="w-1.5 h-1.5 bg-violet-500 rounded-full shrink-0"
                  ></span>
                  Optimized check frequency
                </li>
              </ul>
            </div>
          </div>
        </div>
      </section>

      <!-- How It Works - Visual Flow -->
      <section class="mb-20">
        <div class="flex items-center gap-3 mb-8">
          <div
            class="w-10 h-10 bg-violet-100 rounded-xl flex items-center justify-center"
          >
            <svg
              class="w-5 h-5 text-violet-600"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"
              ></path>
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
            </svg>
          </div>
          <h2 class="text-2xl font-bold text-gray-900">How It Works</h2>
        </div>

        <div class="relative">
          <!-- Connection line -->
          <div
            class="hidden md:block absolute left-1/2 top-12 bottom-12 w-px bg-gradient-to-b from-violet-400 via-violet-200 to-transparent"
          >
          </div>

          <div class="space-y-6">
            <!-- Step 1 -->
            <div class="relative flex items-start gap-6">
              <div class="flex-1 text-right hidden md:block">
                <div
                  class="inline-block bg-white rounded-xl p-5 border border-gray-200 shadow-sm hover:shadow-md transition-shadow"
                >
                  <h3 class="text-gray-900 font-semibold mb-2">Automated Login</h3>
                  <p class="text-gray-500 text-sm">
                    Selenium handles browser automation, logging into the portal
                    and navigating to postings.
                  </p>
                </div>
              </div>
              <div
                class="relative z-10 w-10 h-10 bg-violet-600 rounded-full flex items-center justify-center text-white font-bold shrink-0 shadow-lg shadow-violet-300"
              >
                1
              </div>
              <div class="flex-1 md:hidden">
                <div class="bg-white rounded-xl p-5 border border-gray-200 shadow-sm hover:shadow-md transition-shadow">
                  <h3 class="text-gray-900 font-semibold mb-2">Automated Login</h3>
                  <p class="text-gray-500 text-sm">
                    Selenium handles browser automation, logging into the portal
                    and navigating to postings.
                  </p>
                </div>
              </div>
              <div class="flex-1 hidden md:block"></div>
            </div>

            <!-- Step 2 -->
            <div class="relative flex items-start gap-6">
              <div class="flex-1 hidden md:block"></div>
              <div
                class="relative z-10 w-10 h-10 bg-violet-600 rounded-full flex items-center justify-center text-white font-bold shrink-0 shadow-lg shadow-violet-300"
              >
                2
              </div>
              <div class="flex-1">
                <div class="bg-white rounded-xl p-5 border border-gray-200 shadow-sm hover:shadow-md transition-shadow">
                  <h3 class="text-gray-900 font-semibold mb-2">Scrape & Parse</h3>
                  <p class="text-gray-500 text-sm">
                    BeautifulSoup extracts job details. Duplicate detection
                    ensures we only process new postings.
                  </p>
                </div>
              </div>
            </div>

            <!-- Step 3 -->
            <div class="relative flex items-start gap-6">
              <div class="flex-1 text-right hidden md:block">
                <div
                  class="inline-block bg-white rounded-xl p-5 border border-gray-200 shadow-sm hover:shadow-md transition-shadow"
                >
                  <h3 class="text-gray-900 font-semibold mb-2">Auto-Accept</h3>
                  <p class="text-gray-500 text-sm">
                    When a matching job appears, the bot clicks through and
                    accepts it. No human needed.
                  </p>
                </div>
              </div>
              <div
                class="relative z-10 w-10 h-10 bg-violet-600 rounded-full flex items-center justify-center text-white font-bold shrink-0 shadow-lg shadow-violet-300"
              >
                3
              </div>
              <div class="flex-1 md:hidden">
                <div class="bg-white rounded-xl p-5 border border-gray-200 shadow-sm hover:shadow-md transition-shadow">
                  <h3 class="text-gray-900 font-semibold mb-2">Auto-Accept</h3>
                  <p class="text-gray-500 text-sm">
                    When a matching job appears, the bot clicks through and
                    accepts it. No human needed.
                  </p>
                </div>
              </div>
              <div class="flex-1 hidden md:block"></div>
            </div>

            <!-- Step 4 -->
            <div class="relative flex items-start gap-6">
              <div class="flex-1 hidden md:block"></div>
              <div
                class="relative z-10 w-10 h-10 bg-violet-600 rounded-full flex items-center justify-center text-white font-bold shrink-0 shadow-lg shadow-violet-300"
              >
                4
              </div>
              <div class="flex-1">
                <div class="bg-white rounded-xl p-5 border border-gray-200 shadow-sm hover:shadow-md transition-shadow">
                  <h3 class="text-gray-900 font-semibold mb-2">
                    Push Notification
                  </h3>
                  <p class="text-gray-500 text-sm">
                    Pushover sends an instant alert to her phone with job
                    details. She knows she's booked.
                  </p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- Technical Decisions -->
      <section class="mb-20">
        <div class="flex items-center gap-3 mb-8">
          <div
            class="w-10 h-10 bg-violet-100 rounded-xl flex items-center justify-center"
          >
            <svg
              class="w-5 h-5 text-violet-600"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"
              ></path>
            </svg>
          </div>
          <h2 class="text-2xl font-bold text-gray-900">Technical Decisions</h2>
        </div>

        <div class="grid md:grid-cols-3 gap-4">
          <div
            class="bg-white rounded-xl p-5 border border-gray-200 hover:border-violet-300 transition-colors shadow-sm"
          >
            <div class="text-violet-600 font-mono text-sm mb-2">Selenium</div>
            <h3 class="text-gray-900 font-semibold mb-2">Why not requests?</h3>
            <p class="text-gray-500 text-sm">
              The portal needs real browser interaction - JavaScript execution,
              clicking, form submissions. HTTP requests alone can't handle it.
            </p>
          </div>

          <div
            class="bg-white rounded-xl p-5 border border-gray-200 hover:border-violet-300 transition-colors shadow-sm"
          >
            <div class="text-violet-600 font-mono text-sm mb-2">Pushover</div>
            <h3 class="text-gray-900 font-semibold mb-2">Why this for alerts?</h3>
            <p class="text-gray-500 text-sm">
              Dead simple API, reliable delivery, works on iOS and Android. No
              need to build notification infrastructure.
            </p>
          </div>

          <div
            class="bg-white rounded-xl p-5 border border-gray-200 hover:border-violet-300 transition-colors shadow-sm"
          >
            <div class="text-violet-600 font-mono text-sm mb-2">
              Digital Ocean
            </div>
            <h3 class="text-gray-900 font-semibold mb-2">Why a droplet?</h3>
            <p class="text-gray-500 text-sm">
              Runs 24/7 without my laptop. Set it up once, and it just works.
              Low cost, high uptime.
            </p>
          </div>
        </div>
      </section>

      <!-- Challenges -->
      <section class="mb-20">
        <div class="flex items-center gap-3 mb-8">
          <div
            class="w-10 h-10 bg-violet-100 rounded-xl flex items-center justify-center"
          >
            <svg
              class="w-5 h-5 text-violet-600"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"
              ></path>
            </svg>
          </div>
          <h2 class="text-2xl font-bold text-gray-900">Challenges</h2>
        </div>

        <div
          class="bg-white rounded-xl border border-gray-200 divide-y divide-gray-100 shadow-sm hover:shadow-md transition-shadow"
        >
          <div class="p-5 flex items-start gap-4">
            <div class="w-2 h-2 bg-violet-500 rounded-full mt-2 shrink-0"></div>
            <div>
              <h3 class="text-gray-900 font-medium mb-1">Session Management</h3>
              <p class="text-gray-500 text-sm">
                Handling timeouts and re-authentication when sessions expire
                mid-run.
              </p>
            </div>
          </div>
          <div class="p-5 flex items-start gap-4">
            <div class="w-2 h-2 bg-violet-500 rounded-full mt-2 shrink-0"></div>
            <div>
              <h3 class="text-gray-900 font-medium mb-1">Timing is Everything</h3>
              <p class="text-gray-500 text-sm">
                Too fast and elements aren't ready. Too slow and you miss jobs.
                Finding the balance took iteration.
              </p>
            </div>
          </div>
          <div class="p-5 flex items-start gap-4">
            <div class="w-2 h-2 bg-violet-500 rounded-full mt-2 shrink-0"></div>
            <div>
              <h3 class="text-gray-900 font-medium mb-1">Headless on Linux</h3>
              <p class="text-gray-500 text-sm">
                Running a headless browser on a server is different from local
                development. Different dependencies, different quirks.
              </p>
            </div>
          </div>
          <div class="p-5 flex items-start gap-4">
            <div class="w-2 h-2 bg-violet-500 rounded-full mt-2 shrink-0"></div>
            <div>
              <h3 class="text-gray-900 font-medium mb-1">Check Frequency</h3>
              <p class="text-gray-500 text-sm">
                Aggressive enough to catch jobs, not so aggressive it looks
                suspicious or gets blocked.
              </p>
            </div>
          </div>
        </div>
      </section>

      <!-- Result -->
      <section class="mb-20">
        <div
          class="bg-gradient-to-br from-violet-100 to-white rounded-2xl p-8 md:p-10 border border-violet-200 shadow-sm"
        >
          <div class="flex items-center gap-3 mb-5">
            <div class="w-12 h-12 bg-violet-500 rounded-full flex items-center justify-center">
              <svg
                class="w-6 h-6 text-white"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2.5"
                  d="M5 13l4 4L19 7"
                ></path>
              </svg>
            </div>
            <h2 class="text-2xl font-bold text-gray-900">The Result</h2>
          </div>
          <p class="text-xl md:text-2xl text-gray-700 leading-relaxed font-medium">
            My sister doesn't check the job portal anymore. She gets a
            notification, and the job is already hers. The system has been
            running reliably, and she hasn't missed a job since.
          </p>
        </div>
      </section>

      <!-- What I Learned -->
      <section>
        <div class="flex items-center gap-3 mb-8">
          <div
            class="w-10 h-10 bg-violet-100 rounded-xl flex items-center justify-center"
          >
            <svg
              class="w-5 h-5 text-violet-600"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"
              ></path>
            </svg>
          </div>
          <h2 class="text-2xl font-bold text-gray-900">What I Learned</h2>
        </div>

        <div class="grid md:grid-cols-2 gap-4">
          <div class="bg-white rounded-xl p-5 border border-gray-200 shadow-sm hover:shadow-md transition-shadow">
            <svg class="w-6 h-6 text-violet-300 mb-2" fill="currentColor" viewBox="0 0 24 24">
              <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z" />
            </svg>
            <p class="text-gray-600 italic">
              Web scraping in the real world is messier than tutorials make it
              seem.
            </p>
          </div>
          <div class="bg-white rounded-xl p-5 border border-gray-200 shadow-sm hover:shadow-md transition-shadow">
            <svg class="w-6 h-6 text-violet-300 mb-2" fill="currentColor" viewBox="0 0 24 24">
              <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z" />
            </svg>
            <p class="text-gray-600 italic">
              Building for someone you care about changes how you approach
              reliability.
            </p>
          </div>
          <div class="bg-white rounded-xl p-5 border border-gray-200 shadow-sm hover:shadow-md transition-shadow">
            <svg class="w-6 h-6 text-violet-300 mb-2" fill="currentColor" viewBox="0 0 24 24">
              <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z" />
            </svg>
