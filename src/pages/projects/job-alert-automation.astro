---
import MainLayout from "../../layouts/Layout.astro";
import Nav from "../../components/Nav.astro";
import Footer from "../../components/Footer.astro";

const tags = ["Python", "Selenium", "BeautifulSoup", "Pushover API"];
---

<MainLayout
  title="Jobbot"
  description="A real-time job monitoring and auto-accept system built for substitute teachers"
>
  <Nav />

  <main class="bg-gray-50 min-h-screen">
    <!-- Hero with gradient -->
    <div class="relative overflow-hidden">
      <div
        class="absolute inset-0 bg-gradient-to-br from-violet-100 via-gray-50 to-gray-50"
      >
      </div>
      <div
        class="absolute top-20 left-1/4 w-96 h-96 bg-violet-200/50 rounded-full blur-3xl"
      >
      </div>
      <div
        class="absolute top-40 right-1/4 w-64 h-64 bg-violet-300/40 rounded-full blur-3xl"
      >
      </div>

      <div class="relative pt-32 pb-20 px-6">
        <!-- Back link -->
        <div class="max-w-4xl mx-auto mb-8">
          <a
            href="/#projects"
            class="text-violet-600 hover:text-violet-700 transition-colors inline-flex items-center gap-2 text-sm"
          >
            <svg
              class="w-4 h-4"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M15 19l-7-7 7-7"></path>
            </svg>
            Back to projects
          </a>
        </div>

        <!-- Hero content -->
        <header class="max-w-4xl mx-auto">
          <h1
            class="text-5xl md:text-6xl font-bold text-gray-900 mb-6 tracking-tight"
          >
            Jobbot
          </h1>

          <p
            class="text-xl md:text-xl text-gray-600 mb-8 leading-relaxed max-w-2xl"
          >
            A real-time job monitoring system that scrapes postings and
            auto-accepts opportunities before they're gone.
          </p>

          <div class="flex flex-wrap gap-3 mb-8">
            {
              tags.map((tag) => (
                <span class="px-4 py-2 bg-violet-100 text-violet-700 rounded-lg text-sm font-medium border border-violet-200 backdrop-blur-sm">
                  {tag}
                </span>
              ))
            }
          </div>

          <a
            href="https://github.com/jen444x/job-alert-automation"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-5 py-3 bg-gray-900 text-white font-semibold rounded-xl hover:bg-gray-800 transition-colors"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path
                d="M12 .3a12 12 0 0 0-3.8 23.4c.6.1.8-.3.8-.6v-2c-3.3.7-4-1.6-4-1.6-.6-1.4-1.4-1.8-1.4-1.8-1-.7.1-.7.1-.7 1.2 0 1.9 1.2 1.9 1.2 1 1.8 2.8 1.3 3.5 1 0-.8.4-1.3.7-1.6-2.7-.3-5.5-1.3-5.5-6 0-1.2.5-2.3 1.3-3.1-.2-.4-.6-1.6 0-3.2 0 0 1-.3 3.4 1.2a11.5 11.5 0 0 1 6 0c2.3-1.5 3.3-1.2 3.3-1.2.6 1.6.2 2.8 0 3.2.9.8 1.3 1.9 1.3 3.2 0 4.6-2.8 5.6-5.5 5.9.5.4.9 1 .9 2.2v3.3c0 .3.1.7.8.6A12 12 0 0 0 12 .3"
              ></path>
            </svg>
            View on GitHub
          </a>
        </header>
      </div>
    </div>

    <!-- Content -->
    <article class="max-w-4xl mx-auto px-6 pb-20">
      <!-- Motivation -->
      <section class="mb-20">
        <div class="flex items-center gap-3 mb-6">
          <div
            class="w-10 h-10 bg-violet-100 rounded-xl flex items-center justify-center"
          >
            <svg
              class="w-5 h-5 text-violet-600"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"
              ></path>
            </svg>
          </div>
          <h2 class="text-2xl font-bold text-gray-900">The Story</h2>
        </div>

        <p class="text-gray-600 leading-relaxed mb-8 text-lg">
          My sister worked as a substitute teacher. Job postings go up at random
          times, and if you don't claim them fast, someone else will. So I built
          a bot that runs 24/7, checks the portal every few minutes, and accepts
          jobs automatically.
        </p>

        <!-- Problem / Solution cards -->
        <div class="grid md:grid-cols-2 gap-4 relative">
          <!-- Problem -->
          <div class="relative">
            <div
              class="absolute -top-3 left-4 px-3 py-1 bg-gray-100 text-gray-600 text-xs font-semibold rounded-full border border-gray-200"
            >
              BEFORE
            </div>
            <div
              class="bg-white rounded-2xl p-6 pt-8 border border-gray-200 h-full shadow-sm hover:shadow-md transition-shadow"
            >
              <ul class="space-y-2">
                <li class="flex items-center gap-3 text-gray-600 text-sm">
                  <span class="w-1.5 h-1.5 bg-gray-400 rounded-full shrink-0"
                  ></span>
                  Constantly checking her phone
                </li>
                <li class="flex items-center gap-3 text-gray-600 text-sm">
                  <span class="w-1.5 h-1.5 bg-gray-400 rounded-full shrink-0"
                  ></span>
                  Missing jobs when not checking
                </li>
                <li class="flex items-center gap-3 text-gray-600 text-sm">
                  <span class="w-1.5 h-1.5 bg-gray-400 rounded-full shrink-0"
                  ></span>
                  Waking up extra early
                </li>
                <li class="flex items-center gap-3 text-gray-600 text-sm">
                  <span class="w-1.5 h-1.5 bg-gray-400 rounded-full shrink-0"
                  ></span>
                  Staying up late checking
                </li>
              </ul>
            </div>
          </div>

          <!-- Arrow connector -->
          <div
            class="hidden md:flex absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 z-10"
          >
            <div
              class="w-10 h-10 bg-white rounded-full flex items-center justify-center border border-gray-200 shadow-sm"
            >
              <svg
                class="w-5 h-5 text-violet-600"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
              </svg>
            </div>
          </div>

          <!-- Solution -->
          <div class="relative">
            <div
              class="absolute -top-3 left-4 px-3 py-1 bg-violet-100 text-violet-600 text-xs font-semibold rounded-full border border-violet-200"
            >
              AFTER
            </div>
            <div
              class="bg-white rounded-2xl p-6 pt-8 border border-gray-200 h-full shadow-sm hover:shadow-md transition-shadow"
            >
              <ul class="space-y-2">
                <li class="flex items-center gap-3 text-gray-600 text-sm">
                  <span class="w-1.5 h-1.5 bg-violet-500 rounded-full shrink-0"
                  ></span>
                  Auto-accept or notify only mode
                </li>
                <li class="flex items-center gap-3 text-gray-600 text-sm">
                  <span class="w-1.5 h-1.5 bg-violet-500 rounded-full shrink-0"
                  ></span>
                  Configurable job preferences
                </li>
                <li class="flex items-center gap-3 text-gray-600 text-sm">
                  <span class="w-1.5 h-1.5 bg-violet-500 rounded-full shrink-0"
                  ></span>
                  Blackout dates
                </li>
                <li class="flex items-center gap-3 text-gray-600 text-sm">
                  <span class="w-1.5 h-1.5 bg-violet-500 rounded-full shrink-0"
                  ></span>
                  Optimized check frequency
                </li>
              </ul>
            </div>
          </div>
        </div>
      </section>

      <!-- How It Works -->
      <section class="mb-20">
        <div class="flex items-center gap-3 mb-6">
          <div
            class="w-10 h-10 bg-violet-100 rounded-xl flex items-center justify-center"
          >
            <svg
              class="w-5 h-5 text-violet-600"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M13 5l7 7-7 7M5 5l7 7-7 7"></path>
            </svg>
          </div>
          <h2 class="text-2xl font-bold text-gray-900">How It Works</h2>
        </div>

        <!-- Desktop: horizontal row -->
        <div class="hidden md:grid md:grid-cols-4 gap-4 relative">
          <!-- Connecting line behind cards -->
          <div
            class="absolute top-10 left-[12.5%] right-[12.5%] h-px bg-gradient-to-r from-violet-300 via-violet-400 to-violet-300 z-0"
          >
          </div>

          <!-- Step 1 -->
          <div
            class="relative z-10 bg-white rounded-xl p-5 border border-gray-200 shadow-sm"
          >
            <span class="text-violet-500 text-xs font-semibold tracking-wide"
              >01</span
            >
            <h3 class="text-gray-900 font-semibold mt-1 mb-2">Prepare</h3>
            <p class="text-gray-500 text-sm leading-relaxed">
              Spins up Chrome, logs in, and confirms the session works. If
              something's off, re-login happens before anything else — no silent
              failures downstream.
            </p>
          </div>

          <!-- Step 2 -->
          <div
            class="relative z-10 bg-white rounded-xl p-5 border border-gray-200 shadow-sm"
          >
            <span class="text-violet-500 text-xs font-semibold tracking-wide"
              >02</span
            >
            <h3 class="text-gray-900 font-semibold mt-1 mb-2">Check</h3>
            <p class="text-gray-500 text-sm leading-relaxed">
              Polls the portal on randomized intervals tuned to peak posting
              hours. I looked at when jobs actually post and weighted the
              schedule around those windows. Random timing also keeps the
              pattern from looking mechanical.
            </p>
          </div>

          <!-- Step 3 -->
          <div
            class="relative z-10 bg-white rounded-xl p-5 border border-gray-200 shadow-sm"
          >
            <span class="text-violet-500 text-xs font-semibold tracking-wide"
              >03</span
            >
            <h3 class="text-gray-900 font-semibold mt-1 mb-2">Match</h3>
            <p class="text-gray-500 text-sm leading-relaxed">
              BeautifulSoup parses each posting. The bot filters against her
              preferences — dates, classification, blackouts — and picks the
              first match.
            </p>
          </div>

          <!-- Step 4 -->
          <div
            class="relative z-10 bg-white rounded-xl p-5 border border-gray-200 shadow-sm"
          >
            <span class="text-violet-500 text-xs font-semibold tracking-wide"
              >04</span
            >
            <h3 class="text-gray-900 font-semibold mt-1 mb-2">Act</h3>
            <p class="text-gray-500 text-sm leading-relaxed">
              Accepts the job and pushes a screenshot to her phone with the
              outcome: accepted, found-but-failed, skipped, or error. She wakes
              up to a finished job, not a maybe.
            </p>
          </div>
        </div>

        <!-- Mobile: stacked -->
        <div class="md:hidden space-y-3">
          <div
            class="bg-white rounded-xl p-4 border border-gray-200 shadow-sm flex gap-4"
          >
            <span class="text-violet-500 text-xs font-semibold">01</span>
            <div>
              <h3 class="text-gray-900 font-semibold text-sm mb-1">Prepare</h3>
              <p class="text-gray-500 text-sm">
                Spins up Chrome, logs in, and confirms the session works —
                re-login if something's off, so nothing fails silently
                downstream.
              </p>
            </div>
          </div>
          <div
            class="bg-white rounded-xl p-4 border border-gray-200 shadow-sm flex gap-4"
          >
            <span class="text-violet-500 text-xs font-semibold">02</span>
            <div>
              <h3 class="text-gray-900 font-semibold text-sm mb-1">Check</h3>
              <p class="text-gray-500 text-sm">
                Polls on randomized intervals weighted around peak posting hours
                — tight mornings, looser overnight. Random timing also keeps the
                pattern from looking mechanical.
              </p>
            </div>
          </div>
          <div
            class="bg-white rounded-xl p-4 border border-gray-200 shadow-sm flex gap-4"
          >
            <span class="text-violet-500 text-xs font-semibold">03</span>
            <div>
              <h3 class="text-gray-900 font-semibold text-sm mb-1">Match</h3>
              <p class="text-gray-500 text-sm">
                BeautifulSoup parses each posting. Filters against her
                preferences — dates, classification, blackouts — and picks the
                first match.
              </p>
            </div>
          </div>
          <div
            class="bg-white rounded-xl p-4 border border-gray-200 shadow-sm flex gap-4"
          >
            <span class="text-violet-500 text-xs font-semibold">04</span>
            <div>
              <h3 class="text-gray-900 font-semibold text-sm mb-1">Act</h3>
              <p class="text-gray-500 text-sm">
                Accepts the job and pushes a screenshot showing the outcome:
                accepted, found-but-failed, skipped, or error.
              </p>
            </div>
          </div>
        </div>
      </section>

      <!-- System Architecture -->
      <section class="mb-20">
        <div class="flex items-center gap-3 mb-6">
          <div
            class="w-10 h-10 bg-violet-100 rounded-xl flex items-center justify-center"
          >
            <svg
              class="w-5 h-5 text-violet-600"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"
              ></path>
            </svg>
          </div>
          <h2 class="text-2xl font-bold text-gray-900">System Architecture</h2>
        </div>

        <p class="text-sm text-gray-400 mb-5">
          Hover any module to see implementation details.
        </p>

        <div
          id="arch-diagram-container"
          class="relative bg-white rounded-2xl border border-gray-200 shadow-sm p-4 md:p-6 overflow-x-auto"
        >
          <svg
            width="680"
            height="590"
            viewBox="0 0 680 590"
            xmlns="http://www.w3.org/2000/svg"
            class="w-full max-w-2xl mx-auto"
            font-family="Inter, system-ui, -apple-system, sans-serif"
            role="img"
            aria-label="Job bot system architecture"
          >
            <defs>
              <marker
                id="arch-arrow"
                viewBox="0 0 10 10"
                refX="8"
                refY="5"
                markerWidth="6"
                markerHeight="6"
                orient="auto-start-reverse"
              >
                <path
                  d="M2 1L8 5L2 9"
                  fill="none"
                  stroke="#888780"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"></path>
              </marker>
            </defs>

            <style>
              .box-gray {
                fill: #f1efe8;
                stroke: #5f5e5a;
              }
              .box-purple {
                fill: #eeedfe;
                stroke: #534ab7;
              }
              .box-teal {
                fill: #e1f5ee;
                stroke: #0f6e56;
              }
              .title-gray {
                fill: #2c2c2a;
                font-size: 14px;
                font-weight: 500;
              }
              .title-purple {
                fill: #3c3489;
                font-size: 14px;
                font-weight: 500;
              }
              .title-teal {
                fill: #085041;
                font-size: 14px;
                font-weight: 500;
              }
              .sub-purple {
                fill: #534ab7;
                font-size: 12px;
              }
              .sub-teal {
                fill: #0f6e56;
                font-size: 12px;
              }
              .label {
                fill: #5f5e5a;
                font-size: 12px;
              }
              .arr {
                stroke: #888780;
                stroke-width: 1.5;
                fill: none;
              }
              .arch-module {
                cursor: pointer;
              }
              .arch-module rect {
                transition: stroke-width 0.15s ease;
              }
              .arch-module:hover rect {
                stroke-width: 1.5 !important;
              }
            </style>

            <!-- Job portal -->
            <rect
              x="270"
              y="20"
              width="140"
              height="44"
              rx="8"
              class="box-gray"
              stroke-width="0.5"></rect>
            <text
              x="340"
              y="42"
              text-anchor="middle"
              dominant-baseline="central"
              class="title-gray">Job portal</text
            >

            <!-- Selenium bidirectional arrow -->
            <line
              x1="340"
              y1="64"
              x2="340"
              y2="146"
              class="arr"
              marker-end="url(#arch-arrow)"
              marker-start="url(#arch-arrow)"></line>
            <text x="350" y="108" class="label">Selenium</text>

            <!-- Job Bot dashed border -->
            <rect
              x="60"
              y="110"
              width="560"
              height="300"
              rx="14"
              fill="none"
              stroke="#888780"
              stroke-width="1"
              stroke-dasharray="6 4"></rect>
            <text x="80" y="130" class="label">Job Bot</text>

            <!-- Session orchestrator -->
            <g class="arch-module" data-module="orchestrator">
              <rect
                x="200"
                y="148"
                width="280"
                height="56"
                rx="8"
                class="box-purple"
                stroke-width="0.5"></rect>
              <text
                x="340"
                y="170"
                text-anchor="middle"
                dominant-baseline="central"
                class="title-purple">Session orchestrator</text
              >
              <text
                x="340"
                y="188"
                text-anchor="middle"
                dominant-baseline="central"
                class="sub-purple">run_session, retry_on_failure</text
              >
            </g>

            <!-- driver_manager -->
            <g class="arch-module" data-module="driver">
              <rect
                x="100"
                y="240"
                width="190"
                height="56"
                rx="8"
                class="box-teal"
                stroke-width="0.5"></rect>
              <text
                x="195"
                y="262"
                text-anchor="middle"
                dominant-baseline="central"
                class="title-teal">driver_manager</text
              >
              <text
                x="195"
                y="280"
                text-anchor="middle"
                dominant-baseline="central"
                class="sub-teal">Chrome lifecycle</text
              >
            </g>

            <!-- error_handling -->
            <g class="arch-module" data-module="errors">
              <rect
                x="320"
                y="240"
                width="190"
                height="56"
                rx="8"
                class="box-teal"
                stroke-width="0.5"></rect>
              <text
                x="415"
                y="262"
                text-anchor="middle"
                dominant-baseline="central"
                class="title-teal">error_handling</text
              >
              <text
                x="415"
                y="280"
                text-anchor="middle"
                dominant-baseline="central"
                class="sub-teal">Exceptions, retry</text
              >
            </g>

            <!-- timing -->
            <g class="arch-module" data-module="timing">
              <rect
                x="100"
                y="320"
                width="190"
                height="56"
                rx="8"
                class="box-teal"
                stroke-width="0.5"></rect>
              <text
                x="195"
                y="342"
                text-anchor="middle"
                dominant-baseline="central"
                class="title-teal">timing</text
              >
              <text
                x="195"
                y="360"
                text-anchor="middle"
                dominant-baseline="central"
                class="sub-teal">Randomized waits</text
              >
            </g>

            <!-- notifications -->
            <g class="arch-module" data-module="notifications">
              <rect
                x="320"
                y="320"
                width="190"
                height="56"
                rx="8"
                class="box-teal"
                stroke-width="0.5"></rect>
              <text
                x="415"
                y="342"
                text-anchor="middle"
                dominant-baseline="central"
                class="title-teal">notifications</text
              >
              <text
                x="415"
                y="360"
                text-anchor="middle"
                dominant-baseline="central"
                class="sub-teal">Pushover sender</text
              >
            </g>

            <!-- notifications → Pushover API -->
            <path
              d="M415 376 L415 440"
              class="arr"
              marker-end="url(#arch-arrow)"></path>

            <!-- Pushover API -->
            <rect
              x="345"
              y="440"
              width="140"
              height="44"
              rx="8"
              class="box-gray"
              stroke-width="0.5"></rect>
            <text
              x="415"
              y="462"
              text-anchor="middle"
              dominant-baseline="central"
              class="title-gray">Pushover API</text
            >

            <!-- Pushover → User and Admin -->
            <path
              d="M415 484 L415 505 L250 505 L250 530"
              class="arr"
              marker-end="url(#arch-arrow)"></path>
            <path
              d="M415 484 L415 530"
              class="arr"
              marker-end="url(#arch-arrow)"></path>

            <!-- User -->
            <rect
              x="180"
              y="530"
              width="140"
              height="44"
              rx="8"
              class="box-gray"
              stroke-width="0.5"></rect>
            <text
              x="250"
              y="552"
              text-anchor="middle"
              dominant-baseline="central"
              class="title-gray">User</text
            >

            <!-- Admin (Jen) -->
            <rect
              x="345"
              y="530"
              width="140"
              height="44"
              rx="8"
              class="box-gray"
              stroke-width="0.5"></rect>
            <text
              x="415"
              y="552"
              text-anchor="middle"
              dominant-baseline="central"
              class="title-gray">Admin (Jen)</text
            >
          </svg>
        </div>
      </section>

      <!-- How It Stays Running -->
      <section class="mb-20">
        <div class="flex items-center gap-3 mb-6">
          <div
            class="w-10 h-10 bg-violet-100 rounded-xl flex items-center justify-center"
          >
            <svg
              class="w-5 h-5 text-violet-600"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"
              ></path>
            </svg>
          </div>
          <h2 class="text-2xl font-bold text-gray-900">How It Stays Running</h2>
        </div>

        <p class="text-gray-600 leading-relaxed mb-3 text-lg">
          She stopped checking the portal manually. That means a silent failure
