---
const tags = ["Python", "Selenium", "BeautifulSoup", "Pushover API"];
---

<!-- Hero with gradient -->
<div class="relative overflow-hidden">
  <div
    class="absolute inset-0 bg-gradient-to-br from-violet-100 via-gray-50 to-gray-50"
  >
  </div>
  <div
    class="absolute top-20 left-1/4 w-96 h-96 bg-violet-200/50 rounded-full blur-3xl"
  >
  </div>
  <div
    class="absolute top-40 right-1/4 w-64 h-64 bg-violet-300/40 rounded-full blur-3xl"
  >
  </div>

  <div class="relative pt-32 pb-20 px-6">
    <!-- Back link -->
    <div class="max-w-4xl mx-auto mb-8">
      <a
        href="/#projects"
        class="text-violet-600 hover:text-violet-700 transition-colors inline-flex items-center gap-2 text-sm"
      >
        <svg
          class="w-4 h-4"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M15 19l-7-7 7-7"></path>
        </svg>
        Back to projects
      </a>
    </div>

    <!-- Hero content -->
    <header class="max-w-4xl mx-auto">
      <h1
        class="text-5xl md:text-6xl font-bold text-gray-900 mb-6 tracking-tight"
      >
        Jobbot
      </h1>

      <p
        class="text-xl md:text-xl text-gray-600 mb-8 leading-relaxed max-w-2xl"
      >
        A real-time job monitoring system that scrapes postings and
        auto-accepts opportunities before they're gone.
      </p>

      <div class="flex flex-wrap gap-3 mb-8">
        {
          tags.map((tag) => (
            <span class="px-4 py-2 bg-violet-100 text-violet-700 rounded-lg text-sm font-medium border border-violet-200 backdrop-blur-sm">
              {tag}
            </span>
          ))
        }
      </div>

      <a
        href="https://github.com/jen444x/job-alert-automation"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-5 py-3 bg-gray-900 text-white font-semibold rounded-xl hover:bg-gray-800 transition-colors"
      >
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
          <path
            d="M12 .3a12 12 0 0 0-3.8 23.4c.6.1.8-.3.8-.6v-2c-3.3.7-4-1.6-4-1.6-.6-1.4-1.4-1.8-1.4-1.8-1-.7.1-.7.1-.7 1.2 0 1.9 1.2 1.9 1.2 1 1.8 2.8 1.3 3.5 1 0-.8.4-1.3.7-1.6-2.7-.3-5.5-1.3-5.5-6 0-1.2.5-2.3 1.3-3.1-.2-.4-.6-1.6 0-3.2 0 0 1-.3 3.4 1.2a11.5 11.5 0 0 1 6 0c2.3-1.5 3.3-1.2 3.3-1.2.6 1.6.2 2.8 0 3.2.9.8 1.3 1.9 1.3 3.2 0 4.6-2.8 5.6-5.5 5.9.5.4.9 1 .9 2.2v3.3c0 .3.1.7.8.6A12 12 0 0 0 12 .3"
          ></path>
        </svg>
        View on GitHub
      </a>
    </header>
  </div>
</div>
