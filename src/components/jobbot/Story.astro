<!-- Motivation -->
<section class="mb-20">
  <div class="flex items-center gap-3 mb-6">
    <div
      class="w-10 h-10 bg-violet-100 rounded-xl flex items-center justify-center"
    >
      <svg
        class="w-5 h-5 text-violet-600"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"
        ></path>
      </svg>
    </div>
    <h2 class="text-2xl font-bold text-gray-900">The Story</h2>
  </div>

  <p class="text-gray-600 leading-relaxed mb-8 text-lg">
    My sister worked as a substitute teacher. Jobs post at random times
    (early morning, late at night, etc.) and get claimed in minutes. Miss
    the window, miss the day's pay. She was setting alarms, refreshing the
    portal between meals, staying up late just in case. I built her a bot
    that runs 24/7 and books jobs before she even sees the alert. Now she
    can sleep through a 6am posting and wake up to confirmed work.
  </p>

  <!-- Problem / Solution cards -->
  <div class="grid md:grid-cols-2 gap-4 relative">
    <!-- Problem -->
    <div class="relative">
      <div
        class="absolute -top-3 left-4 px-3 py-1 bg-gray-100 text-gray-600 text-xs font-semibold rounded-full border border-gray-200"
      >
        BEFORE
      </div>
      <div
        class="bg-white rounded-2xl p-6 pt-8 border border-gray-200 h-full shadow-sm hover:shadow-md transition-shadow"
      >
        <ul class="space-y-2">
          <li class="flex items-center gap-3 text-gray-600 text-sm">
            <span class="w-1.5 h-1.5 bg-gray-400 rounded-full shrink-0"
            ></span>
            Constantly checking her phone
          </li>
          <li class="flex items-center gap-3 text-gray-600 text-sm">
            <span class="w-1.5 h-1.5 bg-gray-400 rounded-full shrink-0"
            ></span>
            Missing jobs when she wasn't looking
          </li>
          <li class="flex items-center gap-3 text-gray-600 text-sm">
            <span class="w-1.5 h-1.5 bg-gray-400 rounded-full shrink-0"
            ></span>
            Waking up early just in case
          </li>
          <li class="flex items-center gap-3 text-gray-600 text-sm">
            <span class="w-1.5 h-1.5 bg-gray-400 rounded-full shrink-0"
            ></span>
            Staying up late refreshing
          </li>
        </ul>
      </div>
    </div>

    <!-- Arrow connector -->
    <div
      class="hidden md:flex absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 z-10"
    >
      <div
        class="w-10 h-10 bg-white rounded-full flex items-center justify-center border border-gray-200 shadow-sm"
      >
        <svg
          class="w-5 h-5 text-violet-600"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
        </svg>
      </div>
    </div>

    <!-- Solution -->
    <div class="relative">
      <div
        class="absolute -top-3 left-4 px-3 py-1 bg-violet-100 text-violet-600 text-xs font-semibold rounded-full border border-violet-200"
      >
        AFTER
      </div>
      <div
        class="bg-white rounded-2xl p-6 pt-8 border border-gray-200 h-full shadow-sm hover:shadow-md transition-shadow"
      >
        <ul class="space-y-2">
          <li class="flex items-center gap-3 text-gray-600 text-sm">
            <span class="w-1.5 h-1.5 bg-violet-500 rounded-full shrink-0"
            ></span>
            Wakes up to jobs already booked
          </li>
          <li class="flex items-center gap-3 text-gray-600 text-sm">
            <span class="w-1.5 h-1.5 bg-violet-500 rounded-full shrink-0"
            ></span>
            Sleeps through the night
          </li>
          <li class="flex items-center gap-3 text-gray-600 text-sm">
