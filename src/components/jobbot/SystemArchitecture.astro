<!-- Fixed tooltip for architecture diagram — position set by JS -->
<div
  id="arch-tooltip"
  style="display:none;position:fixed;z-index:9999;background:#111827;border:1px solid #374151;color:#f9fafb;border-radius:12px;padding:14px;width:240px;pointer-events:none;font-size:12px;line-height:1.6;box-shadow:0 20px 25px -5px rgba(0,0,0,0.4);"
>
</div>

<script>
  const tooltipContent: Record<string, string> = {
    orchestrator: `
      <div style="font-weight:600;margin-bottom:8px;">Session Orchestrator</div>
      <div style="color:#d1d5db;margin-bottom:8px;">Runs sessions forever. Each one is 10 job checks with filter and accept.</div>
      <div style="color:#d1d5db;display:flex;flex-direction:column;gap:5px;margin-bottom:10px;">
        <div>· <span style="color:#6ee7b7;font-family:monospace">prepare_session()</span> recovers cheapest-first: refresh → re-login → rebuild driver only if dead</div>
        <div>· <span style="color:#6ee7b7;font-family:monospace">accept_first_job()</span> filters by date, same-day toggle, and classification, then accepts the first job that passes</div>
        <div>· Notifies before accepting, so if the click fails she still sees the job and can grab it herself</div>
      </div>
      <div style="border-left:2px solid #a78bfa;padding-left:8px;">
        <div style="color:#c4b5fd;font-weight:600;margin-bottom:3px;">Stateless restart</div>
        <div style="color:#d1d5db;">If the session crashes, <span style="color:#6ee7b7;font-family:monospace">retry_on_failure</span> runs the whole thing again from scratch. No "resume mid-session" logic. Safer to start clean than reconcile partial state.</div>
      </div>
    `,
    driver: `
      <div style="font-weight:600;margin-bottom:8px;">driver_manager</div>
      <div style="color:#d1d5db;margin-bottom:8px;">Owns the Chrome driver lifecycle.</div>
      <div style="color:#d1d5db;display:flex;flex-direction:column;gap:5px;">
        <div>· Health probe via <span style="color:#6ee7b7;font-family:monospace">driver.current_url</span> (free, no side effects)</div>
        <div>· <span style="color:#6ee7b7;font-family:monospace">destroy_driver()</span> always wipes <span style="color:#6ee7b7;font-family:monospace">/tmp/chrome_jobbot</span> in a <span style="color:#6ee7b7;font-family:monospace">finally</span> block (stale profiles add up on the small droplet)</div>
        <div>· Headless-mode hardening: 3 Chrome flags + JS override of <span style="color:#6ee7b7;font-family:monospace">navigator.webdriver</span></div>
        <div>· Creation failures surface as <span style="color:#fcd34d;font-family:monospace">TemporaryError</span> so the orchestrator can retry</div>
      </div>
    `,
    errors: `
      <div style="font-weight:600;margin-bottom:8px;">error_handling</div>
      <div style="color:#d1d5db;margin-bottom:8px;">Two domain exceptions, one rule: never wake her up for a false alarm.</div>
      <div style="color:#d1d5db;display:flex;flex-direction:column;gap:8px;margin-bottom:10px;">
        <div>· <span style="color:#fcd34d;font-family:monospace">TemporaryError</span>: retry silently <span style="color:#9ca3af;font-style:italic;">(page slow, login timeout, button not yet rendered)</span></div>
        <div>· <span style="color:#f87171;font-family:monospace">PermanentError</span>: stop and notify both <span style="color:#9ca3af;font-style:italic;">(missing credentials, HTML structure changed)</span></div>
        <div>· Selenium errors get classified at the call site, so the retry layer stays simple (just run the function again)</div>
      </div>
      <div style="border-left:2px solid #a78bfa;padding-left:8px;">
        <div style="color:#c4b5fd;font-weight:600;margin-bottom:3px;">Why shallow retries</div>
        <div style="color:#d1d5db;">Retry depth lives at one level (the whole session). Nesting retries inside retries would multiply fast: 2× outer × 3× inner = 6 attempts, another layer = 18. Kept it flat on purpose.</div>
      </div>
    `,
    timing: `
      <div style="font-weight:600;margin-bottom:8px;">timing</div>
      <div style="color:#d1d5db;margin-bottom:8px;">Time-of-day aware waits, weighted from looking at when jobs actually post.</div>
      <div style="color:#d1d5db;display:flex;flex-direction:column;gap:5px;margin-bottom:10px;">
        <div>· Shorter intervals during peak hours, longer overnight</div>
        <div>· Random within each bucket so the request pattern doesn't look mechanical</div>
      </div>
      <div style="border-left:2px solid #a78bfa;padding-left:8px;">
        <div style="color:#c4b5fd;font-weight:600;margin-bottom:3px;">5am edge case</div>
        <div style="color:#d1d5db;">A night wait that would cross 5am gets clipped, then a fresh early-morning wait runs on top. The bot never sleeps through the high-value morning window, and the first check isn't at 5:00 sharp (predictable = bot signal).</div>
      </div>
    `,
    notifications: `
      <div style="font-weight:600;margin-bottom:8px;">notifications</div>
      <div style="color:#d1d5db;margin-bottom:8px;">Two recipient tiers via Pushover API.</div>
      <div style="display:flex;flex-direction:column;gap:7px;margin-bottom:10px;">
        <div style="border-left:2px solid #7c3aed;padding-left:8px;">
          <div style="color:#c4b5fd;font-family:monospace;margin-bottom:2px;">notify_users()</div>
          <div style="color:#d1d5db;">Sister + me · job alerts + screenshots</div>
        </div>
        <div style="border-left:2px solid #4b5563;padding-left:8px;">
          <div style="color:#9ca3af;font-family:monospace;margin-bottom:2px;">notify_admin()</div>
          <div style="color:#d1d5db;">Me only · errors + debug info</div>
        </div>
      </div>
      <div style="color:#d1d5db;display:flex;flex-direction:column;gap:5px;">
        <div>· One <span style="color:#6ee7b7;font-family:monospace">send_notification()</span> does the work, with per-recipient try/except so one failure doesn't block others</div>
        <div>· Screenshots are attached then deleted (bounded disk on the small droplet)</div>
        <div>· <span style="color:#6ee7b7;font-family:monospace">dump_debug()</span> saves HTML + screenshot so I can investigate failures without bothering her</div>
      </div>
    `,
  };

  const tooltip = document.getElementById("arch-tooltip") as HTMLElement | null;
  const modules = document.querySelectorAll<SVGGElement>(".arch-module");

  if (tooltip) {
    modules.forEach((module) => {
      const key = module.dataset.module ?? "";

      module.addEventListener("mouseenter", () => {
        tooltip.innerHTML = tooltipContent[key] ?? "";
        tooltip.style.display = "block";
      });

      module.addEventListener("mouseleave", () => {
        tooltip.style.display = "none";
      });
    });

    document.addEventListener("mousemove", (e) => {
      if (tooltip.style.display === "none") return;
      let x = e.clientX + 14;
      let y = e.clientY + 14;
      if (x + 240 > window.innerWidth - 8) x = e.clientX - 254;
      if (y + tooltip.offsetHeight > window.innerHeight - 8) {
        y = e.clientY - tooltip.offsetHeight - 14;
      }
      tooltip.style.left = x + "px";
      tooltip.style.top = y + "px";
    });
  }
</script>
