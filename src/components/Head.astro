---
// Wwhat information this component needs from other files
export interface Props {
  title: string; // The page title (required)
  description: string; // The page description (required)
}
// Extract the props that were passed to this component
const {
  title = "My Astro Website", // ← Default if no title passed
  description = "Welcome to my website", // ← Default if no description passed
} = Astro.props;

// Astro.site comes from your config file
// Astro.url.pathname is the current page's path (like "/about")
// Combine them to make the full URL
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!-- Basic SEO -->
<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalURL} />

<!-- Open Graph tags (for social media previews-->
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:type" content="website" />
<meta property="og:url" content={canonicalURL} />
<meta property="og:image" content={new URL('/og-image.jpg', Astro.site)} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />

<!-- Twitter Card tags -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={new URL('/og-image.jpg', Astro.site)} />

<!-- Favicon -->
<link rel="icon" href="/favicon.ico" />
