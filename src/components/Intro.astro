<section class="min-h-screen flex items-center justify-center bg-gradient-to-br from-gray-950 via-gray-900 to-gray-950">
  <div class="max-w-4xl mx-auto px-6 py-20 text-center">
    <h1 class="text-5xl md:text-7xl font-bold text-white mb-6 animate-fade-in">
      Hi, I'm Jen!
    </h1>
    <p class="text-xl md:text-2xl text-gray-400 mb-8">
      I like building things that make life easier.
